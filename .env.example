# Database
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
DATABASE_SYNC_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# Redis
REDIS_URL=redis://localhost:6379/0

# RunPod
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# External LLM APIs (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Sentry
SENTRY_DSN=

# App
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
