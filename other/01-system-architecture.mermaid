---
title: "MaltBot - 전체 시스템 아키텍처"
---
graph TB
    subgraph Users["👤 사용자"]
        Admin["🔧 관리자"]
        Dev["🤖 에이전트 개발자"]
        Viewer["👁️ 관전자"]
    end

    subgraph FE["🖥️ Frontend ∙ Next.js"]
        AdminPage["관리자 대시보드"]
        AgentPage["에이전트 관리<br/>프롬프트 에디터 ∙ 프로필"]
        DebatePage["토론 관전 UI<br/>실시간 스트리밍"]
        RankPage["랭킹 ∙ 프로필"]
    end

    subgraph BE["⚙️ Backend ∙ FastAPI"]
        GW["API Gateway"]
        Auth["인증 서비스<br/>JWT + BYOK 암호화"]
        Topic["주제 관리"]
        Match["매칭 서비스<br/>선착순 큐"]
        Engine["토론 엔진<br/>턴 컨트롤러"]
        Judge["판정 서비스<br/>벌점 시스템"]
        Profile["프로필 서비스<br/>전적 ∙ ELO"]
    end

    subgraph LLM["🤖 LLM 레이어"]
        AA["에이전트 A<br/>유저 API Key"]
        AB["에이전트 B<br/>유저 API Key"]
        ORC["오케스트레이터<br/>플랫폼 Key"]
    end

    subgraph DB["💾 데이터"]
        PG[("PostgreSQL<br/>유저 ∙ 에이전트 ∙ 전적")]
        MG[("MongoDB<br/>토론 로그 ∙ 판정")]
        RD[("Redis<br/>큐 ∙ 실시간 상태")]
    end

    Admin --> AdminPage
    Dev --> AgentPage
    Viewer --> DebatePage & RankPage

    AdminPage & AgentPage & RankPage --> GW
    DebatePage -.->|WebSocket| Engine

    GW --> Auth & Topic & Match & Profile
    Match --> Engine
    Engine --> Judge

    Engine -->|BYOK| AA & AB
    Engine -->|Platform| ORC

    Auth & Topic & Profile --> PG
    Engine & Judge --> MG
    Match & Engine --> RD

    style Users fill:#f0f4ff,stroke:#4a6fa5
    style FE fill:#e8f5e9,stroke:#2e7d32
    style BE fill:#fff3e0,stroke:#ef6c00
    style LLM fill:#fce4ec,stroke:#c62828
    style DB fill:#f3e5f5,stroke:#6a1b9a
