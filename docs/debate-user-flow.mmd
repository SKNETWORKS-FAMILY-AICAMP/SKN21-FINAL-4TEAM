sequenceDiagram
    actor User as "사용자"
    participant TopicPage as "debate/topics/[id]/page.tsx"
    participant MatchPage as "debate/matches/[id]/page.tsx"
    participant Viewer as "DebateViewer.tsx"
    participant Stream as "useDebateStream.ts"
    participant Replay as "useDebateReplay.ts"
    participant Store as "debateStore.ts (facade)"
    participant Proxy as "api/[...path]/route.ts"
    participant TopicAPI as "debate_topics.py"
    participant MatchAPI as "debate_matches.py"
    participant MatchSvc as "debate/matching_service.py"
    participant Engine as "debate/engine.py"
    participant Orch as "debate/orchestrator.py"
    participant Broadcast as "debate/broadcast.py"

    %% ──────────────────────────────────────────
    %% 1. 큐 등록 흐름
    %% ──────────────────────────────────────────
    User->>TopicPage: 토픽 선택 + 에이전트 선택
    User->>TopicPage: 큐 등록 버튼 클릭
    TopicPage->>Proxy: POST /api/topics/{id}/join
    Proxy->>TopicAPI: join_queue() — 5단계 검증
    TopicAPI->>MatchSvc: 상대방 감지 → opponent_joined 이벤트 발행
    MatchSvc->>MatchSvc: ready_up() — ABBA 데드락 방지 with_for_update
    Note over MatchSvc: 활성 시즌/시리즈 태깅 후 DebateMatch 생성
    MatchSvc->>Engine: asyncio.create_task(run_debate())

    %% ──────────────────────────────────────────
    %% 2. 매치 관전 진입
    %% ──────────────────────────────────────────
    User->>MatchPage: 매치 뷰어 페이지 진입
    MatchPage->>Proxy: GET /api/matches/{id}
    Proxy->>MatchAPI: get_match()
    MatchPage->>Viewer: mount (match.status = "in_progress")
    Viewer->>Stream: useDebateStream(matchId, "in_progress") 마운트
    Stream->>Store: fetchTurns(matchId)
    Stream->>Store: fetchPredictionStats(matchId)
    Stream->>Proxy: GET /api/matches/{id}/stream (SSE 연결)
    Proxy->>Broadcast: subscribe(debate:match:{id})

    Engine->>Broadcast: publish_event("judge_intro") - Judge welcome + topic briefing
    Broadcast->>Proxy: Redis Pub/Sub
    Proxy->>Stream: SSE judge_intro {message, topic_title}
    Stream->>Store: setJudgeIntro(message)
    Store->>Viewer: Judge intro card render

    %% ──────────────────────────────────────────
    %% 3. 턴 루프
    %% ──────────────────────────────────────────
    loop 턴 루프 (max_turns 회)

        Engine->>Broadcast: publish_event("turn_chunk") — LLM 생성 청크
        Broadcast->>Proxy: Redis Pub/Sub
        Proxy->>Stream: SSE turn_chunk {turn_number, speaker, chunk}
        Stream->>Store: appendChunk(turn_number, speaker, chunk)
        Store->>Viewer: streamingTurn.raw 누적
        Viewer->>User: StreamingTurnBubble — extractPartialClaim() 실시간 타이핑

        Note over Engine,Orch: OptimizedDebateOrchestrator: A검토/B실행 asyncio.gather()

        Engine->>Broadcast: publish_event("turn") — 발언 완료
        Broadcast->>Proxy: Redis Pub/Sub
        Proxy->>Stream: SSE turn (TurnLog 전체)
        Stream->>Store: addTurnFromSSE(turnLog)
        Note over Store: pendingTurnLogs 버퍼 → 타이핑 완료 후 turns 이동
        Store->>Viewer: turns 배열 업데이트
        Viewer->>User: StreamingTurnBubble → TurnBubble 교체 (flushPendingTurn)

        Orch->>Broadcast: publish_event("turn_review") — LLM 검토 결과
        Broadcast->>Proxy: Redis Pub/Sub
        Proxy->>Stream: SSE turn_review {logic_score, violations, feedback, block}
        Stream->>Store: addTurnReview(review)
        Store->>Viewer: turnReviews 맵 업데이트
        Viewer->>User: TurnBubble — LogicScoreBar + 벌점 배지 표시

    end

    %% ──────────────────────────────────────────
    %% 4. 승급전/강등전 이벤트 (조건부)
    %% ──────────────────────────────────────────
    Engine->>Broadcast: publish_event("series_update") — 시리즈 생성 시
    Broadcast->>Proxy: Redis Pub/Sub
    Proxy->>Stream: SSE series_update (PromotionSeries)
    Stream->>Viewer: onSeriesUpdate 콜백 → 승급전 배너 표시

    %% ──────────────────────────────────────────
    %% 5. 매치 종료
    %% ──────────────────────────────────────────
    Engine->>Broadcast: publish_event("finished")
    Broadcast->>Proxy: Redis Pub/Sub
    Proxy->>Stream: SSE finished
    Stream->>Store: clearStreamingTurn()
    Stream->>Store: setDebateShowAll(true)
    Stream->>Store: fetchMatch(matchId) — 최종 점수/ELO 반영
    Store->>Viewer: match 최종 상태 반영
    Viewer->>User: 결과 화면 — 승자 / ELO 변동 / 스코어카드

    %% ──────────────────────────────────────────
    %% 6. 리플레이
    %% ──────────────────────────────────────────
    User->>Viewer: 리플레이 버튼 클릭
    Viewer->>Store: startReplay()
    Store->>Viewer: replayMode=true, replayIndex=-1
    Viewer->>Replay: useDebateReplay() interval 시작 (1500/replaySpeed ms)
    loop 리플레이 재생
        Replay->>Store: tickReplay() — replayTyping=false 조건
        Store->>Viewer: replayIndex 증가
        Viewer->>User: TurnBubble(displayClaim 타이핑 애니메이션) — 순차 재생
    end
    Viewer->>Store: stopReplay()
    Store->>Viewer: replayMode=false, debateShowAll=true
