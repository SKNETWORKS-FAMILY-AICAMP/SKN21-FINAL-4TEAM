flowchart TD
    subgraph ENGINE["engine.py — 코드 기반 벌점"]
        ET["_execute_turn()\nLLM 호출 / WebSocket"]
        ET -->|"응답 수신"| VS["validate_response_schema()\nJSON 파싱 3단계 시도"]
        ET -->|"finish_reason=length"| TL["token_limit\nPENALTY_TOKEN_LIMIT = 3"]
        ET -->|"타임아웃 / 호출 오류"| TO["timeout\nPENALTY_TIMEOUT = 5"]
        ET -->|"tool_result 위조"| FS["false_source\nPENALTY_FALSE_SOURCE = 7"]
        VS -->|"파싱 실패"| SV["schema_violation\nPENALTY_SCHEMA_VIOLATION = 5"]
        VS -->|"파싱 성공"| DR["detect_repetition()\n단어 중복 70%+ 감지"]
        DR -->|"반복 탐지"| REP["repetition\nPENALTY_REPETITION = 3"]
        DR -->|"정상"| CLAIM["claim 추출 완료"]
    end

    subgraph ORCH["orchestrator.py — LLM 기반 벌점"]
        RT["review_turn()\ngpt-4o-mini 호출\n(REVIEW_SYSTEM_PROMPT 주입)"]
        RT -->|"violations[] 반환"| BRR["_build_review_result()\nLLM_VIOLATION_PENALTIES 조회"]
        BRR --> LVP

        subgraph LVP["LLM_VIOLATION_PENALTIES 매핑"]
            direction LR
            P1["prompt_injection → 10"]
            P2["ad_hominem → 8"]
            P3["false_claim → 7"]
            P4["straw_man → 6"]
            P5["off_topic / hasty_generalization\ngenetic_fallacy / appeal\nslippery_slope → 5"]
            P6["circular_reasoning / accent\ndivision / composition → 4"]
        end

        BRR -->|"block=true"| BLK["발언 차단\n대체 텍스트 삽입"]
        BRR -->|"logic_score (1-10)"| LS["논증품질 점수 기록"]
    end

    subgraph AGG["engine.py — 벌점 누적"]
        ART["_apply_review_to_turn()\n코드 벌점 + LLM 벌점 합산\nturn.penalty_total 저장"]
        ACC["매 턴 누적\ntotal_penalty_a\ntotal_penalty_b"]
        ART --> ACC
        ACC -->|"매치 종료"| MP["match.penalty_a\nmatch.penalty_b 저장"]
    end

    subgraph JUDGE["orchestrator.py — 최종 판정"]
        FDL["_format_debate_log()\n전체 턴 로그 포매팅"]
        KO["PENALTY_KO_LABELS 변환\n영문 키 → 한국어 라벨\n(Judge LLM에 노출되는 언어)"]
        JM["_judge_with_model()\ngpt-4.1 호출\n(JUDGE_SYSTEM_PROMPT 주입)"]

        subgraph SC["SCORING_CRITERIA (100점 만점)"]
            direction LR
            S1["logic 30"]
            S2["evidence 25"]
            S3["rebuttal 25"]
            S4["relevance 20"]
        end

        FDL --> KO --> JM
        JM --> SC
        JM -->|"A/B 라벨 랜덤 스왑\n발언 순서 편향 제거"| SWAP["scorecard 역변환"]
    end

    subgraph FINAL["최종 점수 계산"]
        FS2["final_a = max(0, judge_a - penalty_a)\nfinal_b = max(0, judge_b - penalty_b)"]
        ELO["calculate_elo()\n점수차 배수 ELO\nnew_elo_a, new_elo_b"]
        FS2 --> ELO
    end

    %% 주요 연결
    CLAIM --> RT
    SV & REP & TL & TO & FS --> ART
    LVP --> ART
    LS --> FDL
    MP --> FS2
    SWAP --> FS2

    %% 스타일
    classDef engineNode fill:#1e3a5f,stroke:#38bdf8,color:#e2e8f0
    classDef orchNode fill:#3b1f5e,stroke:#a855f7,color:#e2e8f0
    classDef penaltyNode fill:#4a1c1c,stroke:#f87171,color:#fca5a5
    classDef koNode fill:#854d0e,stroke:#f97316,color:#fed7aa
    classDef scoreNode fill:#14532d,stroke:#4ade80,color:#bbf7d0
    classDef finalNode fill:#1e293b,stroke:#94a3b8,color:#e2e8f0

    class ET,VS,DR,ART,ACC,MP engineNode
    class RT,BRR,JM,FDL,SWAP orchNode
    class SV,REP,TL,TO,FS,BLK,P1,P2,P3,P4,P5,P6 penaltyNode
    class KO koNode
    class S1,S2,S3,S4,LS scoreNode
    class FS2,ELO finalNode
